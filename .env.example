# .env.example — copie este arquivo para .env 
# NUNCA versione o arquivo .env no Git

# Django
DJANGO_SECRET_KEY=your-very-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados MySQL
DB_NAME=agrogestao_db
DB_USER=agrogestao_user
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=3306

# Sessão
SESSION_COOKIE_AGE=28800
SESSION_EXPIRE_AT_BROWSER_CLOSE=False

# E-mail
DEFAULT_FROM_EMAIL=noreply@agrogestao.com.br
EMAIL_HOST=smtp.seuprovedor.com.br
EMAIL_PORT=587
EMAIL_HOST_USER=seu@email.com
EMAIL_HOST_PASSWORD=sua_senha_smtp
